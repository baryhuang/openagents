<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
	  App Sandbox is disabled for the macOS DMG build. GoogleSignIn's
	  keychain caching needs `keychain-access-groups`, which in turn
	  requires a Developer ID provisioning profile (regulated entitlement).
	  Disabling sandbox sidesteps both — keychain access just works, and
	  no profile dance is needed for ad-hoc Developer ID distribution.
	  Most non-MAS Developer ID apps (Slack, Chrome, etc.) ship without
	  sandbox; this app talks to local shells / agent processes anyway,
	  which sandbox would block.
	-->
	<key>com.apple.security.files.user-selected.read-only</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
</dict>
</plist>
