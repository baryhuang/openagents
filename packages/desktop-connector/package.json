{
  "name": "openagents-connector",
  "version": "0.1.0",
  "description": "OpenAgents Desktop Connector — install, configure, and manage agents",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --remote-debugging-port=9222 --remote-allow-origins=*",
    "build:win": "electron-builder --win --publish never",
    "build:mac": "electron-builder --mac --publish never",
    "build:linux": "electron-builder --linux --publish never",
    "build:all": "electron-builder --win --mac --linux --publish never",
    "dist": "electron-builder --publish always"
  },
  "author": "OpenAgents",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/openagents-org/openagents.git",
    "directory": "packages/desktop-connector"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "dependencies": {
    "@openagents-org/agent-connector": "^0.2.7"
  },
  "build": {
    "appId": "com.openagents.connector",
    "productName": "OpenAgents Connector",
    "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "node_modules/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "portable",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": ["x64", "arm64"]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.developer-tools"
    },
    "dmg": {
      "title": "${productName} ${version}",
      "contents": [
        { "x": 130, "y": 220 },
        { "x": 410, "y": 220, "type": "link", "path": "/Applications" }
      ]
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Development",
      "desktop": {
        "StartupNotify": "true"
      }
    },
    "publish": {
      "provider": "github",
      "owner": "openagents-org",
      "repo": "openagents"
    }
  }
}
