{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist-electron",
    "rootDir": "src",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "types": ["node"],
    "sourceMap": true,
    "incremental": true,
    "tsBuildInfoFile": "dist-electron/.tsbuildinfo-preload"
  },
  "include": [
    "src/preload/**/*.ts",
    "src/shared/**/*.ts"
  ]
}
