<?xml version="1.0" encoding="utf-8"?>
<!--
  SignPath artifact configuration for the OpenAgents Launcher (Windows).

  This is the version-controlled copy of the artifact configuration that must be
  pasted into the SignPath portal:
    Project "openagents" → Artifact Configurations → slug "windows-installers".

  IMPORTANT: the root element MUST be <zip-file>. The GitHub Actions artifacts
  connector always delivers the uploaded artifact as a zip (here
  `launcher-windows-tosign.zip`), so a config rooted at <msi-file>/<pe-file>
  fails with "the file does not correspond to the specified file type".

  The build uploads exactly two files at the zip root (verified):
    - OpenAgents-Launcher-<ver>-win-x64.exe   (NSIS installer)
    - OpenAgents-Launcher-<ver>-win-x64.msi
  SignPath requires every file in the zip to be matched, so both are covered
  below and Authenticode-signed (signs the installer/MSI wrapper).

  Docs: https://docs.signpath.io/artifact-configuration/
-->
<artifact-configuration xmlns="http://signpath.io/artifact-configuration/v1">
  <zip-file>
    <pe-file path="*.exe">
      <authenticode-sign />
    </pe-file>
    <msi-file path="*.msi">
      <authenticode-sign />
    </msi-file>
  </zip-file>
</artifact-configuration>
