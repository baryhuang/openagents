    },
    "adapter": {
      "module": "openagents.adapters.nanoclaw",
      "class": "NanoClawAdapter"
    },
    "launch": {
      "args": [
        null
      ]
    },
    "env_config": [
      {
        "name": "OPENAI_API_KEY",
        "description": "API key for LLM inference",
        "required": true,
        "password": true
      }
    ],
    "check_ready": {
      "env_vars": [
        "OPENAI_API_KEY"
      ],
      "saved_env_key": "OPENAI_API_KEY",
      "not_ready_message": "No API key \u2014 press e to configure"
    },
    "resolve_env": {
      "rules": [
        {
          "from": "LLM_API_KEY",
          "to": "OPENAI_API_KEY"
        },
        {
          "from": "LLM_BASE_URL",
          "to": "OPENAI_BASE_URL"
        },
        {
          "from": "LLM_MODEL",
          "to": "NANOCLAW_MODEL"
        }
      ]
    }
