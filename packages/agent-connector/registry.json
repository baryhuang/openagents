    "label": "OpenClaw",
    "description": "Open-source coding agent with multi-model support",
    "homepage": "https://github.com/openagents/openclaw",
    "tags": [
      "coding",
      "open-source"
    ],
    "featured": true,
    "order": 2,
    "support": { "install": true, "workspace": true, "collaboration": true },
