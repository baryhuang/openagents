    },
    "adapter": {
      "module": "openagents.adapters.openclaw",
      "class": "OpenClawAdapter",
      "options": {
        "openclaw_host": "127.0.0.1",
        "openclaw_port": 18789,
        "openclaw_agent_id": "main"
      }
    },
    "env_config": [
      {
        "name": "LLM_API_KEY",
        "description": "API key",
        "required": true,
        "password": true
      },
