{
    "mod_name": "n8n",
    "version": "0.1.0",
    "description": "Integration with n8n workflows and AI Agents. Allows agents to trigger n8n workflows via webhooks and interact with n8n-hosted AI agents.",
    "authors": ["OpenAgents Team"],
    "license": "MIT",
    "agent_adapter_class": "N8nAgentAdapter",
    "network_mod_class": "N8nMod",
    "capabilities": [
        "workflow_triggering",
        "agent_interaction",
        "webhook_integration"
    ],
    "requires_adapter": true,
    "dependencies": [],
    "metadata": {
        "external_service": "n8n",
        "tools": [
            "call_n8n_workflow",
            "interact_with_n8n_agent"
        ],
        "config_options": [
            "base_url",
            "api_key"
        ],
        "env_variables": [
            "N8N_BASE_URL",
            "N8N_API_KEY"
        ]
    }
}
