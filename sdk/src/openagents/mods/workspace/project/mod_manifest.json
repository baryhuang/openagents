{
    "mod_name": "default",
    "version": "1.0.0",
    "description": "Default project mod for OpenAgents that provides project-based collaboration with dedicated channels and service agents",
    "authors": ["OpenAgents Team"],
    "license": "MIT",
    "agent_adapter_class": "DefaultProjectAgentAdapter",
    "network_mod_class": "DefaultProjectNetworkMod",
    "capabilities": [
        "project_management",
        "project_based_collaboration",
        "service_agent_coordination",
        "project_lifecycle_management"
    ],
    "requires_adapter": true,
    "studio_interface": true,
    "dependencies": [
        "openagents.mods.workspace.default"
    ],
    "metadata": {
        "project_type": "default",
        "core_features": [
            "project_creation_and_management",
            "private_channel_creation",
            "service_agent_coordination",
            "project_lifecycle_events",
            "long_horizon_task_support"
        ],
        "tools": [
            "start_project",
            "get_project_status",
            "list_projects",
            "stop_project",
            "get_project_messages"
        ]
    },
    "process_events": [
        "project_creation",
        "project_status",
        "project_notification",
        "project_channel",
        "project_list",
        "agent.connected",
        "agent.disconnected"
    ],
    "generate_events": [
        "project.created",
        "project.started",
        "project.stopped",
        "project.status.changed",
        "project.run.completed",
        "project.run.failed",
        "project.run.requires_input",
        "project.run.notification",
        "project.agent.joined",
        "project.agent.left"
    ],
    "default_config": {
        "max_concurrent_projects": 10,
        "default_service_agents": [],
        "project_channel_prefix": "project-",
        "auto_invite_service_agents": true,
        "project_timeout_hours": 24,
        "enable_project_persistence": true
    },
    "config_schema": {
        "sections": [
            {
                "id": "general",
                "title": "General Settings",
                "description": "General configuration for project management",
                "fields": [
                    {
                        "key": "max_concurrent_projects",
                        "type": "number",
                        "label": "Max Concurrent Projects",
                        "description": "Maximum number of projects that can run simultaneously",
                        "default": 10,
                        "min": 1,
                        "max": 100,
                        "required": true
                    },
                    {
                        "key": "auto_invite_service_agents",
                        "type": "boolean",
                        "label": "Auto-invite Service Agents",
                        "description": "Automatically add service agents to new projects",
                        "default": true
                    },
                    {
                        "key": "project_channel_prefix",
                        "type": "string",
                        "label": "Project Channel Prefix",
                        "description": "Prefix for project channel names",
                        "default": "project-",
                        "maxLength": 20
                    },
                    {
                        "key": "project_timeout_hours",
                        "type": "number",
                        "label": "Project Timeout (hours)",
                        "description": "Hours before an inactive project times out",
                        "default": 24,
                        "min": 1,
                        "max": 168
                    },
                    {
                        "key": "enable_project_persistence",
                        "type": "boolean",
                        "label": "Enable Project Persistence",
                        "description": "Save project state to disk for recovery",
                        "default": true
                    }
                ]
            }
        ]
    }
}
